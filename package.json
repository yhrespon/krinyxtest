{
  "name": "whatsapp-bot",
  "version": "1.1.0",
  "description": "WhatsApp Bot avec QR Code et Pairing Code - Optimisé VPS",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node --expose-gc index.js",
    "dev": "nodemon --experimental-modules index.js",
    "production": "NODE_ENV=production node --expose-gc --max-old-space-size=512 index.js",
    "pm2": "pm2 start index.js --name whatsapp-bot --node-args='--expose-gc --max-old-space-size=512'",
    "pm2-stop": "pm2 stop whatsapp-bot",
    "pm2-restart": "pm2 restart whatsapp-bot",
    "pm2-logs": "pm2 logs whatsapp-bot",
    "clean": "rm -rf node_modules package-lock.json && npm install"
  },
  "author": "SAMY",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.21",
    "axios": "^1.6.3",
    "body-parser": "^1.20.2",
    "chalk": "^5.3.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.0.0",
    "fs-extra": "^11.1.1",
    "helmet": "^7.0.0",
    "pino": "^8.21.0",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.33.1",
    "moment-timezone": "^0.5.45"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "optionalDependencies": {
    "buffer": "^6.0.3",
    "pg": "^8.11.1",
    "mysql2": "^3.6.0",
    "firebase-admin": "^12.0.0",
    "jsonwebtoken": "^9.0.0",
    "bcryptjs": "^2.4.3",
    "express-session": "^1.17.3",
    "cookie-parser": "^1.4.6",
    "session-file-store": "^1.5.0"
  },
  "peerDependencies": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "ws": "^8.14.2"
  },
  "resolutions": {
    "ws": "^8.14.2"
  },
  "bugs": {
    "url": "https://github.com/yourusername/whatsapp-bot/issues"
  },
  "homepage": "https://github.com/yourusername/whatsapp-bot#readme",
  "keywords": [
    "whatsapp",
    "bot",
    "whatsapp-bot",
    "baileys",
    "whatsapp-api",
    "vps",
    "deployment"
  ]
}
